NODE_ENV=development
PORT=4000

# Set strong value (32+ chars) for production
JWT_SECRET=replace_with_long_random_secret

# Comma-separated allowed frontend origins in production
# Local example:
# CORS_ORIGIN=http://localhost:5173
# Firebase Hosting production example:
# CORS_ORIGIN=https://your-project-id.web.app,https://your-project-id.firebaseapp.com,https://www.your-memory.com
CORS_ORIGIN=http://localhost:5173

# General API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Auth endpoint rate limit（テスト公開時は厳しめ推奨）
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# Optional: reCAPTCHA v3（本番テスト公開時は推奨）。フロントに VITE_RECAPTCHA_SITE_KEY も設定。
RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.3
