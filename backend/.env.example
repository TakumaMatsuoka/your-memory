NODE_ENV=development
PORT=4000

# Set strong value (32+ chars) for production
JWT_SECRET=replace_with_long_random_secret

# Comma-separated allowed frontend origins in production
# Local example:
# CORS_ORIGIN=http://localhost:5173
# Firebase Hosting production example:
# CORS_ORIGIN=https://your-project-id.web.app,https://your-project-id.firebaseapp.com,https://www.your-memory.com
CORS_ORIGIN=http://localhost:5173

# General API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Auth endpoint rate limit
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
